    "id": "execute.dryRun.stream-throttle",
    "description": "Dry-run execution of a create-then-patch stream plan preserves patch order.",
    "operation": "execute.dryRun",
    "input": {
      "plan": {
        "kind": "chat.call_plan",
        "operation": "messages.stream",
        "dryRun": true,
        "capability": {
          "ok": true,
