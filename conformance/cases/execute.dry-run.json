            "https://www.googleapis.com/auth/chat.bot"
          ],
          "reasons": []
        },
        "requests": [
          {
            "resource": "spaces.messages.create",
            "method": "POST",
            "path": "/v1/spaces/AAA/messages",
            "query": {
              "requestId": "req-fixed",
              "messageId": "client-fixed"
            },
            "body": {
              "text": "Thinking..."
            }
          },
          {
            "resource": "spaces.messages.patch",
            "method": "PATCH",
            "path": "/v1/spaces/AAA/messages/M1",
            "query": {
              "updateMask": "text"
            },
            "body": {
              "text": "first"
            },
            "throttle": {
              "minDelayMs": 750,
              "final": false
            }
          },
          {
            "resource": "spaces.messages.patch",
            "method": "PATCH",
            "path": "/v1/spaces/AAA/messages/M1",
            "query": {
              "updateMask": "text"
            },
            "body": {
              "text": "first second"
            },
            "throttle": {
              "minDelayMs": 0,
              "final": true
            }
          }
        ],
        "idempotency": {
          "requestId": "req-fixed",
          "clientMessageId": "client-fixed"
        },
        "streaming": {
          "strategy": "create-then-patch",
          "throttleMs": 750,
          "patchCount": 2
        },
        "safety": {
          "liveAllowed": false,
          "directMessage": false,
          "notes": [
            "Dry run only; no Google Chat API call was executed."
