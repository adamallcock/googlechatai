{
  "name": "googlechatai",
  "version": "0.1.0-beta.1",
  "description": "Node.js package for the Google Chat AI SDK.",
  "license": "Apache-2.0",
  "author": "Adam Allcock",
  "keywords": [
    "google-chat",
    "google-workspace",
    "chatbot",
    "chat-app",
    "ai",
    "sdk",
    "streaming",
    "cards"
  ],
  "homepage": "https://github.com/adamallcock/googlechatai#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamallcock/googlechatai.git",
    "directory": "packages/node"
  },
  "bugs": {
    "url": "https://github.com/adamallcock/googlechatai/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "googlechatai": "./cli/index.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "cli",
    "templates",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.9"
  }
}
