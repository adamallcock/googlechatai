GOOGLE_CLOUD_PROJECT=chat-ai-sdk
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# Service account used by local app-auth smoke scripts.
GOOGLE_CHAT_SDK_SERVICE_ACCOUNT_EMAIL=codex-441@chat-ai-sdk.iam.gserviceaccount.com
# Service account used by the deployed Cloud Run webhook.
GOOGLE_CHAT_CLOUD_RUN_SERVICE_ACCOUNT_ID=chat-ai-sdk-runtime
GOOGLE_CHAT_CLOUD_RUN_SERVICE_ACCOUNT=chat-ai-sdk-runtime@chat-ai-sdk.iam.gserviceaccount.com
GOOGLE_CHAT_CLOUD_RUN_SERVICE=chat-ai-sdk-dev-webhook
GOOGLE_CHAT_ARTIFACT_REPOSITORY=chat-ai-sdk
CLOUDSDK_ACTIVE_CONFIG_NAME=llm-googlechat
WORKSPACE_EVENTS_PUBSUB_TOPIC=chat-ai-sdk-workspace-events
WORKSPACE_EVENTS_PUBSUB_SUBSCRIPTION=chat-ai-sdk-workspace-events-dev-pull
GOOGLE_CHAT_SMOKE_PUBSUB_TOPIC=chat-ai-sdk-smoke-tests
GOOGLE_CHAT_SMOKE_PUBSUB_SUBSCRIPTION=chat-ai-sdk-smoke-tests-dev-pull
BASE_URL=
GOOGLE_CHAT_BASE_URL=
GOOGLE_CHAT_WEBHOOK_URL=

# Firestore idempotency monitor and optional production Cloud Run Job.
GOOGLE_CHAT_IDEMPOTENCY_FIRESTORE_DATABASE=(default)
GOOGLE_CHAT_IDEMPOTENCY_FIRESTORE_COLLECTION=googleChatEventIdempotency
GOOGLE_CHAT_IDEMPOTENCY_TTL_FIELD=expiresAt
GOOGLE_CHAT_IDEMPOTENCY_MONITOR_AUTH=service-account-key
GOOGLE_CHAT_IDEMPOTENCY_MONITOR_CLOUD_LOG_NAME=googlechatai-idempotency-monitor
GOOGLE_CHAT_IDEMPOTENCY_MONITOR_JOB=chat-ai-sdk-idempotency-monitor
GOOGLE_CHAT_IDEMPOTENCY_MONITOR_JOB_SERVICE_ACCOUNT=
GOOGLE_CHAT_IDEMPOTENCY_MONITOR_SCHEDULER_JOB=chat-ai-sdk-idempotency-monitor-scheduler
GOOGLE_CHAT_IDEMPOTENCY_MONITOR_SCHEDULE="*/30 * * * *"

# Per-user OAuth for live user-installed Chat app testing. Store the OAuth
# client JSON outside the repo and keep token stores under ignored .tokens/.
GOOGLE_CHAT_OAUTH_CLIENT_CREDENTIALS=/absolute/path/to/oauth-client.json
GOOGLE_CHAT_USER_TOKEN_STORE=.tokens/google-chat-user-oauth-token.json
GOOGLE_CHAT_OAUTH_REDIRECT_URI=

# Filled after the Chat app is configured in Google Cloud Console.
GOOGLE_CHAT_APP_NAME=
GOOGLE_CHAT_TEST_SPACE=
GOOGLE_CHAT_SMOKE_METADATA=fixtures/live/chat-smoke-space.local.json
GOOGLE_CHAT_CUSTOMER=customers/my_customer

# Optional voice-note transcription. Keep real keys in .env.local only.
OPENAI_API_KEY=
RUN_LIVE_TRANSCRIPTION_SMOKE=
RUN_LIVE_TRANSCRIPTION_SAMPLE_DOWNLOAD=
GOOGLE_CHAT_TRANSCRIPTION_SMOKE_RUN_ID=
OPENAI_TRANSCRIPTION_SMOKE_AUDIO=

# Optional Directory identity enrichment and local caches.
GOOGLE_CHAT_DIRECTORY_IDENTITY_CACHE=.cache/googlechatai/identity.json
GOOGLE_CHAT_ARTIFACT_CACHE_DIR=.cache/googlechatai/artifacts
