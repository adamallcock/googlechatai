{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/googlechatai/errors.schema.json",
  "title": "Normalized SDK Error",
  "type": "object",
  "required": ["code", "message", "category", "retryable"],
  "additionalProperties": true,
  "properties": {
    "code": { "type": "string" },
    "message": { "type": "string" },
    "category": {
      "type": "string",
      "enum": [
        "validation",
        "auth",
        "permission",
        "not_found",
        "rate_limit",
        "google_api",
        "network",
        "timeout",
        "unsupported",
        "internal",
        "unknown"
      ]
    },
    "retryable": { "type": "boolean" },
    "retryAfterMs": { "type": ["integer", "null"], "minimum": 0 },
    "httpStatus": { "type": ["integer", "null"], "minimum": 100, "maximum": 599 },
    "principal": {
      "type": ["string", "null"],
      "enum": ["app", "user", "admin", "none", null]
    },
    "intent": { "type": ["string", "null"] },
    "summary": { "type": "string" },
    "remediation": {
      "type": "array",
      "items": { "type": "string" }
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    },
    "source": { "type": ["string", "null"] },
    "capability": {
      "anyOf": [
        { "$ref": "capabilities.schema.json" },
        { "type": "null" }
      ]
    },
    "cause": {
      "type": ["object", "null"],
      "additionalProperties": true
    }
  }
}
